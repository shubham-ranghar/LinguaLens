# Copy to .env and fill in values before running dev/build.
# Variables must be prefixed with VITE_ (or WXT_) to be exposed to extension code.

# MyMemory translation API
VITE_MYMEMORY_API_URL=https://api.mymemory.translated.net/get

# Free Dictionary API (English definitions / synonyms)
VITE_DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en

# Google Gemini generateContent endpoint (user supplies API key in Options)
VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# FreeLLM / LinguaLens AI proxy (OpenAI-compatible chat completions base)
VITE_FREELLM_BASE_URL=https://lingualens-proxy.onrender.com

# Shared secret sent as X-Extension-Secret to the FreeLLM proxy
VITE_FREELLM_EXTENSION_SECRET=replace-with-your-extension-secret

# Space-separated origins allowed in extension_pages connect-src CSP
VITE_CSP_CONNECT_ORIGINS=https://api.mymemory.translated.net https://api.dictionaryapi.dev https://generativelanguage.googleapis.com https://freellmapi-0lx8.onrender.com https://lingualens-proxy.onrender.com
