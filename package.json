{
  "name": "lingualens",
  "description": "AI-powered browser translation and language learning extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env JITI_CACHE=false wxt",
    "dev:firefox": "cross-env JITI_CACHE=false wxt -b firefox",
    "build": "cross-env JITI_CACHE=false wxt build",
    "build:firefox": "cross-env JITI_CACHE=false wxt build -b firefox",
    "zip": "cross-env JITI_CACHE=false wxt zip",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.2.2",
    "franc": "^6.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wxt": "^0.20.27"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/chrome": "^0.2.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
